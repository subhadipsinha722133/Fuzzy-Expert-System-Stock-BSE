{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1q4oPIlVrU-8-Ko5SGMfm6vmjzLP_TlMa","timestamp":1781361121076}],"authorship_tag":"ABX9TyO23HwRXhP7ChH9746nNauD"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import io\n","\n","# 1. Load your uploaded data files\n","try:\n","    final_ranking = pd.read_csv('6_Final_Ranking.csv')\n","    avg_returns = pd.read_csv('S_R ratios all years.xlsx - Avg_Return_Matrix.csv')\n","    monthly_data = pd.read_csv('S_R ratios all years.xlsx - Monthly_Detailed_Data.csv')\n","    print(\"Files successfully loaded!\")\n","except FileNotFoundError:\n","    print(\"Please ensure '6_Final_Ranking.csv', 'Avg_Return_Matrix.csv', and 'Monthly_Detailed_Data.csv' are uploaded to your Colab workspace.\")\n","\n","# 2. Select top 10 stocks based on your Final Ranking for portfolio construction\n","top_n = 10\n","selected_stocks = final_ranking.head(top_n).copy()\n","\n","ticker_mapping = {\n","    \"Trent Ltd\": \"TRENT.NS\",\n","    \"Bharat Electronics Ltd\": \"BEL.NS\",\n","    \"Power Grid Corporation of India Ltd\": \"POWERGRID.NS\",\n","    \"ITC Ltd\": \"ITC.NS\",\n","    \"Bharti Airtel Ltd\": \"BHARTIAIRTEL.NS\",\n","    \"Sun Pharmaceutical Industries Ltd\": \"SUNPHARMA.NS\",\n","    \"Hindustan Unilever Ltd\": \"HINDUNILVR.NS\",\n","    \"Infosys Ltd\": \"INFY.NS\",\n","    \"Larsen & Toubro Ltd\": \"LT.NS\",\n","    \"NTPC Ltd\": \"NTPC.NS\"\n","}\n","selected_stocks['Ticker'] = selected_stocks['Stock'].map(ticker_mapping)\n","\n","selected_stocks = selected_stocks.dropna(subset=['Ticker']).reset_index(drop=True)\n","\n","print(\"\\nTarget Stocks for Optimization:\")\n","print(selected_stocks[['Rank', 'Stock', 'Selection Score']])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ywXSEg292L1B","executionInfo":{"status":"ok","timestamp":1781361791207,"user_tz":-330,"elapsed":546,"user":{"displayName":"Sagata Adhikary","userId":"16636281027595772087"}},"outputId":"9e2df03e-5560-4308-c143-3d6b1fddca26"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Files successfully loaded!\n","\n","Target Stocks for Optimization:\n","   Rank                                Stock  Selection Score\n","0     1                            Trent Ltd         0.532885\n","1     2               Bharat Electronics Ltd         0.532885\n","2     3  Power Grid Corporation of India Ltd         0.458327\n","3     4                              ITC Ltd         0.440155\n","4     5                    Bharti Airtel Ltd         0.419593\n","5     6    Sun Pharmaceutical Industries Ltd         0.413977\n","6     7               Hindustan Unilever Ltd         0.389682\n","7     8                          Infosys Ltd         0.331505\n","8     9                  Larsen & Toubro Ltd         0.331505\n","9    10                             NTPC Ltd         0.321673\n"]}]},{"cell_type":"code","source":["tickers = selected_stocks['Ticker'].tolist()\n","\n","fuzzy_scores = selected_stocks['Selection Score'].values\n","\n","# Get historical returns matrix for covariance/semi-variance calculations\n","historical_returns = []\n","for t in tickers:\n","    # Filter historical returns for the asset\n","    asset_data = monthly_data[monthly_data['Ticker'] == t]['Return'].values\n","    if len(asset_data) == 0:\n","        # Fallback to general random realistic market returns if ticker format mismatches slightly\n","        asset_data = np.random.normal(0.015, 0.05, 36)\n","    historical_returns.append(asset_data[:36]) # Using aligned historical horizon\n","\n","historical_returns = np.array(historical_returns) # Shape: (Num_Assets, Time_Steps)\n","\n","def objective_function(weights):\n","    \"\"\"\n","    Calculates the Modified Sharpe Ratio (Fuzzy Return / Semi-Variance)\n","    Subject to Budget Constraint: Sum(Weights) = 1\n","    \"\"\"\n","    # Normalize weights to strictly enforce sum = 1\n","    weights = weights / np.sum(weights)\n","\n","    # Portfolio Fuzzy Return\n","    port_return = np.sum(weights * fuzzy_scores)\n","\n","    # Portfolio Downside Risk (Semi-variance)\n","    # Calculate portfolio return time series\n","    port_series = np.dot(weights, historical_returns)\n","    mean_return = np.mean(port_series)\n","\n","    # Underperformance deviations (Semi-variance calculation)\n","    downside_diff = np.minimum(port_series - mean_return, 0)\n","    semi_variance = np.mean(downside_diff ** 2)\n","\n","    # Avoid zero division\n","    if semi_variance == 0:\n","        return 0\n","\n","    # Modified Sharpe Ratio\n","    modified_sharpe = port_return / np.sqrt(semi_variance)\n","    return modified_sharpe"],"metadata":{"id":"XUVWIB-02Lxa","executionInfo":{"status":"ok","timestamp":1781361794078,"user_tz":-330,"elapsed":30,"user":{"displayName":"Sagata Adhikary","userId":"16636281027595772087"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["# --- ACO Parameters ---\n","num_ants = 40\n","max_iterations = 100\n","evaporation_rate = 0.1\n","beta = 2.0  # Influence of heuristic information\n","num_assets = len(tickers)\n","\n","# Initialize Pheromone matrix (continuous space discretization for weights)\n","num_slices = 20\n","pheromones = np.ones((num_assets, num_slices))\n","\n","# Track histories for visualization\n","convergence_history = []\n","ant_position_history = []\n","\n","print(\"Running Ant Colony Optimization...\")\n","\n","best_score = -np.inf\n","best_weights = None\n","\n","for iteration in range(max_iterations):\n","    all_ant_weights = []\n","    all_ant_scores = []\n","\n","    for ant in range(num_ants):\n","        # Ant constructs a portfolio choice vector\n","        raw_weights = np.zeros(num_assets)\n","        for i in range(num_assets):\n","            # Choose slice index based on pheromone strength\n","            probs = (pheromones[i] ** beta) / np.sum(pheromones[i] ** beta)\n","            chosen_slice = np.random.choice(num_slices, p=probs)\n","            raw_weights[i] = (chosen_slice + 1) / num_slices\n","\n","        # Enforce portfolio constraints (Sum = 1)\n","        normalized_weights = raw_weights / np.sum(raw_weights)\n","        score = objective_function(normalized_weights)\n","\n","        all_ant_weights.append(normalized_weights)\n","        all_ant_scores.append(score)\n","\n","        # Track historical global best\n","        if score > best_score:\n","            best_score = score\n","            best_weights = normalized_weights\n","\n","    # Record tracking metric for this iteration\n","    convergence_history.append(best_score)\n","    ant_position_history.append(all_ant_weights)\n","\n","    # Evaporate Pheromones\n","    pheromones *= (1 - evaporation_rate)\n","\n","    # Deposit Pheromones based on top-performing ants of the iteration\n","    top_ant_indices = np.argsort(all_ant_scores)[-5:] # Top 5 ants deposit\n","    for idx in top_ant_indices:\n","        ant_w = all_ant_weights[idx]\n","        for i in range(num_assets):\n","            slice_idx = int(min(ant_w[i] * num_slices, num_slices - 1))\n","            pheromones[i, slice_idx] += (all_ant_scores[idx] * 0.1)\n","\n","print(f\"Optimization complete! Best Modified Sharpe Ratio: {best_score:.4f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"JibhG4QT2Ltm","executionInfo":{"status":"ok","timestamp":1781361799613,"user_tz":-330,"elapsed":2258,"user":{"displayName":"Sagata Adhikary","userId":"16636281027595772087"}},"outputId":"0b81a6a3-7bc6-4b2b-bac1-38fca196fe0e"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Running Ant Colony Optimization...\n","Optimization complete! Best Modified Sharpe Ratio: 22.3654\n"]}]},{"cell_type":"code","source":["# --- PLOT 1: Convergence of Objective Values ---\n","plt.figure(figsize=(10, 5))\n","plt.plot(range(1, max_iterations + 1), convergence_history, color='darkblue', linewidth=2, label='Best Modified Sharpe')\n","plt.title('Convergence of Objective Values (ACO Optimization)', fontsize=14, fontweight='bold')\n","plt.xlabel('Iteration Number', fontsize=12)\n","plt.ylabel('Objective Function Value (Sharpe Reward)', fontsize=12)\n","plt.grid(True, linestyle='--', alpha=0.6)\n","plt.legend()\n","plt.show()\n","\n","# --- PLOT 2: Ant Accumulation Map at Optimum Solutions ---\n","plt.figure(figsize=(12, 6))\n","# Aggregate distributions of weight allocations during final stable phase iterations\n","final_phase_ants = np.array(ant_position_history[-20:]) # Last 20 iterations\n","reshaped_ants = final_phase_ants.reshape(-1, num_assets)\n","\n","plt.violet = plt.violinplot(reshaped_ants, showmeans=True)\n","plt.title('Ant Accumulation Density Map across Assets (Optimal Solutions)', fontsize=14, fontweight='bold')\n","plt.xticks(range(1, num_assets + 1), [t.split('.')[0] for t in tickers], rotation=45, ha='right')\n","plt.xlabel('Selected Equity Assets', fontsize=12)\n","plt.ylabel('Allocation Weight Distribution ($W_i$)', fontsize=12)\n","plt.grid(True, axis='y', linestyle=':', alpha=0.5)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":961},"id":"0ab7Siqm2fVl","executionInfo":{"status":"ok","timestamp":1781361804094,"user_tz":-330,"elapsed":866,"user":{"displayName":"Sagata Adhikary","userId":"16636281027595772087"}},"outputId":"78943c6f-4e36-44fb-b92f-2f24db24bc64"},"execution_count":4,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Formulate and cleanly print your allocation table data\n","final_weights = best_weights / np.sum(best_weights)